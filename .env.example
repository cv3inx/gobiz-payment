# GoBiz / GoPay Credentials
# Opsi A — auto-login pakai email + password:
# Nilai string SELALU pakai quote (wajib kalau ada #, spasi, atau char spesial).
GOPAY_EMAIL="your-email@example.com"
GOPAY_PASSWORD="your-password"

# Opsi B — pakai access_token langsung (tanpa login).
# Ambil dari browser: F12 → Application → Cookies → access_token.
# Merchant ID isi manual (kalau kosong, dideteksi otomatis dari token).
# Token menang kalau diisi; refresh manual saat expired.
GOPAY_ACCESS_TOKEN=""
GOPAY_MERCHANT_ID=""

# String QRIS statis milik merchant (didapat dari gambar QRIS GoPay kamu)
# Bisa scan gambar QRIS menggunakan scanner, lalu paste hasilnya di sini
QRIS_STRING="00020101021226..."

# Nominal pembayaran default (dalam Rupiah), dipakai jika tidak ada argumen CLI
PRICE_AMOUNT=2000

# ── Payment Gateway (server.js) ──────────────────────────────────
PORT=3000
POLL_MS=7000
EXPIRE_MINUTES=5   # umur transaksi default (menit). Override per-trx via body.expireMinutes

# Kode unik random (rupiah) yg SELALU ditambah ke amount+fee buat matching.
# amountToPay = amount + fee + random(1..UNIQUE_CODE_MAX). Contoh: 100 -> 152
UNIQUE_CODE_MAX=999

# Public base URL for absolute qrImageUrl (mis. di belakang reverse proxy/domain).
# Kosong = diturunkan dari host request. Contoh: https://pay.tokoku.com
PUBLIC_URL=""

# SQLite file (default: ./data/transaction.db)
DB_FILE=""

# Rate limit: max requests per IP per 60s window
RATE_MAX=60

# Webhook default (bisa dioverride per-trx via body.callbackUrl)
WEBHOOK_URL="https://your-app.example.com/webhook"
WEBHOOK_SECRET="change-me"
# Verifikasi: HMAC-SHA256(secret, rawBody) == header X-Signature

# Optional: proteksi endpoint tulis. Kosongkan untuk nonaktif.
API_KEY=""
