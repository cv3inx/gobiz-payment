{
  "name": "gobiz-grab",
  "version": "1.0.0",
  "description": "Node.js module untuk berinteraksi dengan API GoBiz (GoPay Merchant) — riwayat transaksi & pemantauan pembayaran real-time.",
  "type": "module",
  "main": "lib/gobiz.js",
  "exports": "./lib/gobiz.js",
  "scripts": {
    "start": "node server.js",
    "test": "node src/server.test.js",
