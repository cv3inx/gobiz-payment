    "crc": "^4.3.2",
    "dotenv": "^16.4.5",
    "express": "^4.22.2",
    "moment-timezone": "^0.5.45",
    "morgan": "^1.11.0",
    "qrcode": "^1.5.4",
    "swagger-ui-express": "^5.0.1"
  }
